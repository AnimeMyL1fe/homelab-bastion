services:
  db:
    image: postgres
    restart: always
    shm_size: 128mb
    environment:
      POSTGRES_USER: "{{ db_app_user }}"    
      POSTGRES_PASSWORD: '{{ db_app_password }}'
      POSTGRES_DB: "{{ db_name }}"
      PGDATA: /var/lib/postgresql/data/pgdata
    volumes:
      - postgres_data:/var/lib/postgresql
    ports:
      - "5432:5432" 
    networks:
      - lab_network

  adminer:
    image: adminer
    restart: always
    networks:
      - lab_network
    ports:
      - "8443:8080"

volumes:
  postgres_data:

networks:
  lab_network:
    name: lab_network