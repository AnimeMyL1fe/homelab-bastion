<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LAB-HOST // Production</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }
        body {
            background-color: #0d0d0f;
            color: #e2e8f0;
            font-family: 'Courier New', Courier, monospace;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            width: 100vw;
            padding: 24px;
            overflow-x: hidden;
        }
        .container {
            text-align: center;
            max-width: 1000px; 
            width: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        h1 {
            font-size: calc(1.5rem + 1vw); 
            letter-spacing: 0.4rem;
            margin-bottom: 30px;
            text-transform: uppercase;
            text-shadow: 0 0 15px rgba(255,255,255,0.08);
            width: 100%;
        }
        .image-wrapper {
            position: relative;
            margin-bottom: 30px;
            border: 1px solid #222226;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.7);
            width: 100%;
            max-width: 100%;
            overflow: hidden;
        }
        .image-wrapper img {
            width: 100%;
            height: auto;
            display: block;
            object-fit: cover;
            filter: grayscale(15%) contrast(105%);
            transition: transform 0.5s ease;
        }
        .image-wrapper:hover img {
            transform: scale(1.02);
        }
        p {
            font-size: calc(0.85rem + 0.2vw);
            color: #8c8c93;
            letter-spacing: 0.15rem;
            line-height: 1.6;
            margin-bottom: 20px;
            padding: 0 10px;
        }
        .status {
            display: inline-block;
            font-size: 0.8rem;
            color: #34d399; 
            background: rgba(52, 211, 153, 0.06);
            padding: 6px 16px;
            border-radius: 4px;
            border: 1px solid rgba(52, 211, 153, 0.15);
            letter-spacing: 0.05rem;
        }

        @media (max-width: 480px) {
            body {
                padding: 16px;
            }
            h1 {
                letter-spacing: 0.2rem;
                margin-bottom: 20px;
            }
            .status {
                padding: 6px 12px;
                font-size: 0.75rem;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>Welcome to Lab-Host</h1>
        <div class="image-wrapper">
            <img src="anime.jpg" alt="Yoru">
        </div>
        <p> THE LAB. INFRASTRUCTURE AS CODE. 2026.</p>
        <div class="status">// HOSTED BY 'AnimeMyL1fe' </div>
    </div>
</body>
</html>